const openingMeta = (s.metaphors && s.metaphors.opening) || s.metaphor || '';
const closingMeta = (s.metaphors && s.metaphors.closing) || '';
currentArticleData = {
title: s.title, newsChain: s.newsChain,
causalStory: s.causalStory + '\n\n' + (closingMeta ? closingMeta + '\n\n' : '') + '📌 あなたはこのシナリオ、何点だと思う？コメントで教えてください！',
stocks: s.stocks, metaphor: openingMeta, metaphors: s.metaphors,
probability: s.probability, probabilityReason: s.probabilityReason || ''
};

displayPreview(currentArticleData);

