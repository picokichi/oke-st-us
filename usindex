// コンプライアンスチェックプロンプト
document.getElementById('compliancePrompt').value = '【金融コンプライアンスチェック依頼】\n以下の記事データを金融規制（日本の金融商品取引法・米国SECルール）の観点でチェックしてください。\n\n【チェック項目】\n1. 断定的な投資判断を示す表現がないか（「必ず上がる」「確実に儲かる」など）\n2. 根拠のない株価予測をしていないか\n3. 特定銘柄への過度な推奨表現がないか\n4. 免責事項が適切か\n5. 風説の流布に該当する表現がないか\n\n【判定結果の出力形式】\n問題なし → "OK: 問題は見つかりませんでした"\n問題あり → "NG: （具体的な問題箇所と修正案）"\n\n記事データ:\nタイトル: ' + currentArticleData.title + '\nストーリー: ' + currentArticleData.causalStory.substring(0, 500) + '...\n銘柄: ' + currentArticleData.stocks.map(s => s.name + '(' + s.code + ') 予想:' + s.prediction).join(', ');

document.getElementById('previewCard').style.display = 'block';
document.getElementById('scenarioCard').style.display = 'none';
